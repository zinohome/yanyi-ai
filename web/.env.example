# ===== 数据库（PostgreSQL）=====
# 本地开发：docker-compose.yml 把容器的 5432 映射到本机 5433。
# 注意端口与库名 —— 本机 5432/yanyi_web 属于 yanyi-health，切勿指向它：
# pnpm seed 会先清空所有 collection，足以抹掉那个站点的内容。
DATABASE_URL=postgresql://yanyi:yanyi_dev_pw@127.0.0.1:5433/yanyi_ai
# 生产 docker compose：host 用服务名 postgres，例如：
# DATABASE_URL=postgresql://yanyi:强密码@postgres:5432/yanyi_ai

# 首次连接空数据库时设为 1，让 Payload 自动创建 schema
PAYLOAD_DB_PUSH=1

# ===== Payload =====
# 生成随机密钥：openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SITE_URL=https://www.yanyi-ai.com

# ===== docker-compose.prod.yml 使用的 Postgres 凭据 =====
POSTGRES_USER=yanyi
POSTGRES_PASSWORD=请设置强密码
POSTGRES_DB=yanyi_ai

# ===== 邮件通知（填写后，表单留资自动发到 NOTIFY_EMAIL；163 邮箱用「客户端授权码」作为 SMTP_PASS）=====
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-account@example.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-account@example.com
NOTIFY_EMAIL=contact@yanyi-ai.com
